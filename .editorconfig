root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{kt,kts}]
max_line_length = 120
ktlint_code_style = ktlint_official
# Jetpack Compose names @Composable UI functions in PascalCase by convention; exempt them and
# their lambda-parameter equivalents from the lowercase function-naming rule.
ktlint_function_naming_ignore_when_annotated_with = Composable
ktlint_function_signature_body_expression_wrapping = default
